{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Maven: Build Project",
      "type": "shell",
      "command": "./mvnw",
      "args": ["clean", "install"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$maven"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true
      }
    },
    {
      "label": "Maven: Run All Tests",
      "type": "shell",
      "command": "./mvnw",
      "args": ["test"],
      "group": "test",
      "problemMatcher": ["$maven"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true
      }
    },
    {
      "label": "Maven: Run Functional Tests",
      "type": "shell",
      "command": "./mvnw",
      "args": ["test", "-Dtest=br.com.wallet.project.functional.*"],
      "group": "test",
      "problemMatcher": ["$maven"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true
      }
    },
    {
      "label": "Maven: Run Unit Tests",
      "type": "shell",
      "command": "./mvnw",
      "args": ["test", "-Dtest=br.com.wallet.project.unit.*"],
      "group": "test",
      "problemMatcher": ["$maven"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true
      }
    },
    {
      "label": "Maven: Run Application",
      "type": "shell",
      "command": "./mvnw",
      "args": ["spring-boot:run"],
      "isBackground": false,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true
      }
    },
    {
      "label": "Maven: Run Cucumber Tests",
      "type": "shell",
      "command": "./mvnw",
      "args": ["test", "-Dtest=CucumberTest"],
      "group": "test",
      "problemMatcher": ["$maven"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true
      }
    },
    {
      "label": "Docker: Start Services (PostgreSQL, Kafka, Redis)",
      "type": "shell",
      "command": "cd src/main/resources/compose && docker-compose up -d && echo '✓ Services started!'",
      "isBackground": false,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true
      }
    },
    {
      "label": "Docker: Stop Services",
      "type": "shell",
      "command": "cd src/main/resources/compose && docker-compose down && echo '✓ Services stopped!'",
      "isBackground": false,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true
      }
    }
  ]
}
